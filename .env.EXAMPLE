# ============================================
# Centiria GSM - Environment Configuration
# Game Server Management for Arma Reforger
# ============================================

# App version (use 'latest' for most recent)
VERSION=latest

# Storage path for server files, mods, and logs
# VPS: /home/centiria-gsm/storage
STORAGE_PATH=/home/centiria-gsm/storage

# ─── Web UI Credentials ─────────────────────
AUTH_USERNAME=admin
AUTH_PASSWORD=CHANGE_ME

# ─── Database Settings ──────────────────────
MYSQL_DB_NAME=centiria_gsm_db
# Linux VPS (host network mode):
MYSQL_DB_URL=jdbc:mysql://localhost:3306/centiria_gsm_db
MYSQL_USER=centiria_gsm
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME

# ─── Steam API Key ──────────────────────────
# Required for Steam Workshop mod management
# Generate at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=

# ─── Security Secrets ───────────────────────
# JWT secret for authentication (min 32 characters)
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_STRING_OF_AT_LEAST_32_CHARS

# Database encryption secret (AES-256 key, optional)
# Generate at: https://www.allkeysgenerator.com/Random/Security-Encryption-Key-Generator.aspx
# No '$' symbols allowed
DATABASE_ENCRYPTION_SECRET=

# ─── Timezone ────────────────────────────────
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Asia/Kuala_Lumpur
